{
    "name": "task-runner",
    "version": "1.0.0",
    "description": "A lightweight CLI tool for executing tasks defined in YAML configuration files",
    "main": "src/index.ts",
    "bin": {
        "task-runner": "./dist/task-runner"
    },
    "type": "module",
    "scripts": {
        "build": "bun build src/index.ts --outfile=dist/task-runner --target=bun",
        "build:linux": "bun build src/index.ts --outfile=dist/alf-linux-x64 --target=bun --compile --target=bun-linux-x64",
        "dev": "bun --watch src/index.ts",
        "test": "bun test",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [
        "cli",
        "task-runner",
        "yaml",
        "automation"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/bun": "latest",
        "@types/js-yaml": "^4.0.9",
        "prettier": "^3.6.2"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "js-yaml": "^4.1.0"
    }
}
