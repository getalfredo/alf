{
    "name": "task-runner",
    "version": "1.0.0",
    "description": "A lightweight CLI tool for executing tasks defined in YAML configuration files",
    "main": "src/index.ts",
    "bin": "./dist/alf",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "test": "bun test",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "build:macos": "bun build --compile --target=bun --outfile=dist/alf-macos ./src/index.ts",
        "build:linux": "bun build src/index.ts --outfile=dist/alf-linux-x64 --target=bun-linux-x64 --compile",
        "build": "bun run build:linux && bun run build:macos"
    },
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/bun": "latest",
        "@types/js-yaml": "^4.0.9",
        "prettier": "^3.6.2"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "commander": "^14.0.0",
        "js-yaml": "^4.1.0"
    }
}
